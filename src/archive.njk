---
layout: base.njk
title: Archive
permalink: /archive/
---
<section class="hero" style="margin-bottom:1.1rem;">
  <span class="hero-kicker">Timeline</span>
  <h1>Archive</h1>
  <p>Everything published, in one clean list.</p>
</section>

<ul class="archive-list">
{% for item in collections.everything %}
  <li>
    <time datetime="{{ item.date | isoDate }}">{{ item.date | readableDate }}</time>
    {% if item.data.linkUrl %}
    <a href="{{ item.url }}">{{ item.data.title }} ↗</a>
    {% else %}
    <a href="{{ item.url }}">{{ item.data.title }}</a>
    {% endif %}
  </li>
{% endfor %}
</ul>
