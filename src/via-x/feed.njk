---
permalink: /via-x/feed.xml
eleventyExcludeFromCollections: true
layout: false
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }} — Via X</title>
  <subtitle>Bookmarks worth keeping, with a thought on each.</subtitle>
  <link href="{{ site.url }}{{ '/via-x/feed.xml' | url }}" rel="self"/>
  <link href="{{ site.url }}{{ '/via-x/' | url }}"/>
  {% set lastItem = collections["via-x"] | last %}
  <updated>{% if lastItem %}{{ lastItem.date | isoDate }}{% else %}{{ "2026-01-01" | isoDate }}{% endif %}</updated>
  <id>{{ site.url }}{{ '/via-x/' | url }}</id>
  <author>
    <name>{{ site.author }}</name>
  </author>
  {% for item in collections["via-x"] | reverse %}
  <entry>
    <title>{{ item.data.title }}</title>
    <link href="{{ site.url }}{{ item.url | url }}"/>
    <updated>{{ item.date | isoDate }}</updated>
    <id>{{ site.url }}{{ item.url | url }}</id>
    <content type="html">{{ item.templateContent | safe }}</content>
  </entry>
  {% endfor %}
</feed>
