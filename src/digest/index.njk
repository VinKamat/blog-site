---
layout: base.njk
title: AI Daily Digest
eleventyExcludeFromCollections: true
pagination:
  data: collections.digest
  size: 1
  alias: digestItems
  reverse: true
permalink: "{% if pagination.pageNumber == 0 %}/digest/{% else %}/digest/page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<div class="digest-header">
  <span class="digest-kicker">AI Daily Digest</span>
  <h1>Your daily briefing on AI worth knowing.</h1>
  <p class="digest-subtitle">Curated AI news with commentary from an enterprise architecture perspective.</p>
  <p class="digest-rss"><a href="{{ '/digest/feed.xml' | url }}">Subscribe via RSS ↗</a></p>
</div>

{% set currentDigest = digestItems[0] %}

{% if currentDigest %}
<article>
  <h2>{{ currentDigest.data.title }}</h2>
  <div class="meta">
    <time datetime="{{ currentDigest.date | isoDate }}">{{ currentDigest.date | readableDate }}</time>
  </div>
  {{ currentDigest.templateContent | safe }}
</article>

{% if pagination.pages.length > 1 %}
<nav class="pagination-nav" aria-label="Digest navigation">
  {% if pagination.href.previous %}
  <a class="pagination-link pagination-prev" href="{{ pagination.href.previous | url }}">← Newer Issue</a>
  {% else %}
  <span class="pagination-link pagination-prev pagination-disabled" aria-hidden="true"></span>
  {% endif %}

  <span class="pagination-page-info">Issue {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>

  {% if pagination.href.next %}
  <a class="pagination-link pagination-next" href="{{ pagination.href.next | url }}">Older Issue →</a>
  {% else %}
  <span class="pagination-link pagination-next pagination-disabled" aria-hidden="true"></span>
  {% endif %}
</nav>
{% endif %}

{% else %}
<p style="color: var(--text-muted); font-style: italic; margin-top: 1rem;">No digests yet. The first one is coming.</p>
{% endif %}
