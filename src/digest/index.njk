---
layout: base.njk
title: AI Daily Digest
permalink: /digest/
---
<div class="digest-header">
  <h1>🤖 AI Daily Digest</h1>
  <p class="digest-subtitle">A daily curated feed of AI news, with commentary from an enterprise architecture perspective.</p>
  <p class="digest-rss"><a href="{{ '/digest/feed.xml' | url }}">RSS Feed ↗</a></p>
</div>

{% for item in collections.digest | reverse %}
<div class="feed-item">
  <h2><a href="{{ item.url | url }}">{{ item.data.title }}</a></h2>
  <div class="meta">
    <time datetime="{{ item.date | isoDate }}">{{ item.date | readableDate }}</time>
  </div>
  <div class="excerpt">
    {{ item.templateContent | safe }}
  </div>
</div>
{% endfor %}

{% if collections.digest.length == 0 %}
<p style="color: var(--text-muted); font-style: italic;">No digests yet. The first one is coming.</p>
{% endif %}
